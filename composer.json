{
    "name": "ultimate-multisite/superdav-ai-language-packs",
    "description": "Automatically provides AI-generated translations for WordPress plugins when official translations are missing or incomplete.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Ultimate Multisite Community",
            "homepage": "https://ultimatemultisite.com"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "config": {
        "platform": {
            "php": "7.4.0"
        },
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true,
            "pondermatic/composer-archive-project": true
        }
    },
    "autoload": {
        "classmap": [
            "src"
        ]
    },
    "homepage": "https://github.com/Ultimate-Multisite/superdav-ai-language-packs",
    "support": {
        "issues": "https://github.com/Ultimate-Multisite/superdav-ai-language-packs/issues",
        "source": "https://github.com/Ultimate-Multisite/superdav-ai-language-packs"
    },
    "archive": {
        "name": "superdav-ai-language-packs",
        "exclude": [
            "/.*",
            "/*",
            "!/LICENSE",
            "!/readme.txt",
            "!/src/",
            "!/src/**",
            "!/superdav-ai-language-packs.php"
        ]
    },
    "scripts": {
        "build": "@composer archive-project --format=zip --dir=./ --file=superdav-ai-language-packs"
    },
    "require-dev": {
        "phpstan/extension-installer": "^1.1",
        "pondermatic/composer-archive-project": "^1.1",
        "szepeviktor/phpstan-wordpress": "^2.0"
    }
}
